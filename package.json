{
  "name": "lucky-island",
  "private": true,
  "version": "0.4.0",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10 <11"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:frontend",
    "test:frontend": "vitest run",
    "build:frontend": "vite build",
    "build": "pnpm typecheck && pnpm build:frontend",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "clippy:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --locked -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib --locked",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml --locked",
    "check:native-runtime": "node scripts/check-native-runtime.mjs",
    "release:check-version": "node scripts/check-version.mjs",
    "release:validate-assets": "node scripts/validate-updater-assets.mjs",
    "verify": "pnpm typecheck && pnpm test:frontend && pnpm build:frontend && pnpm fmt:rust && pnpm clippy:rust && pnpm test:rust && pnpm check:rust",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "klinecharts": "9.8.12",
    "lucide-react": "^0.468.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.2.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
